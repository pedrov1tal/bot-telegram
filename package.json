{
  "name": "bot-telegram",
  "version": "2.0.0",
  "description": "Bot Telegram com TypeScript e SWC para enviar promoções da Amazon em tempo real",
  "main": "dist/index.js",
  "scripts": {
    "build": "swc ./src -d dist",
    "dev": "npm run build && NODE_ENV=development node dist/index.js",
    "start": "npm run build && NODE_ENV=production node dist/index.js",
    "build:watch": "swc ./src -d dist --watch",
    "logs": "tail -f logs/bot-*.log",
    "logs:clear": "rm -f logs/bot-*.log",
    "clean": "rm -rf dist logs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "telegram",
    "bot",
    "amazon",
    "scraping",
    "typescript",
    "swc"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "node-telegram-bot-api": "^0.67.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.1.62",
    "@swc/core": "^1.3.99",
    "@types/cheerio": "^0.22.31",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}

# 🤖 Configurações do Bot Telegram

# Token do bot (obtenha em @BotFather no Telegram)
TOKEN=seu_token_aqui

# ID do canal onde as promoções serão enviadas
CANAL_ID=seu_canal_id_aqui

# ID do afiliado Amazon (para rastrear comissões)
AFILIADO=seu_id_afiliado_aqui

# Intervalo de envio em milissegundos (padrão: 1 hora = 3600000)
INTERVALO_ENVIO=3600000

# Modo de ambiente (development ou production)
NODE_ENV=development

# Nível de log (info, error, debug)
LOG_LEVEL=info

# Diretório de logs
LOG_DIR=./logs
